<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>Domi Dom · Online</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,800&family=Outfit:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#071633;--panel:#0e2350;--panel-2:#0a1c41;--ink:#f5f8ff;--muted:#9fb2d8;
    --felt:#0e6b4c;--felt-2:#0a5239;--tile:#faf6ea;--tile-edge:#cdc4ad;--pip:#15241d;
    --red:#ce1126;--blue:#1d4ed8;--gold:#f5c542;--teamA:#f5c542;--teamB:#4d8bff;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  body{font-family:'Outfit',sans-serif;background:radial-gradient(circle at 85% -10%,#1d4ed8,transparent 50%),radial-gradient(circle at -5% 105%,rgba(206,17,38,.28),transparent 45%),var(--bg);color:var(--ink);min-height:100vh;overflow-x:hidden}
  .wrap{max-width:1180px;margin:0 auto;padding:18px}
  .top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:6px}
  .logo{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:32px;letter-spacing:-1px;display:flex;align-items:center;gap:12px;color:#fff;text-shadow:0 2px 10px rgba(0,0,0,.4)}
  .logo .d1{color:var(--red)}
  .flagmark{width:30px;height:30px;border-radius:7px;flex:0 0 auto;position:relative;overflow:hidden;box-shadow:0 3px 10px rgba(0,0,0,.5);background:linear-gradient(90deg,var(--blue) 0 46%,#fff 46% 54%,var(--red) 54% 100%)}
  .flagmark::after{content:'';position:absolute;inset:0;background:linear-gradient(0deg,transparent 0 46%,#fff 46% 54%,transparent 54% 100%)}
  .tag{color:var(--muted);font-size:12px;letter-spacing:1px;text-transform:uppercase}
  .hbar{display:flex;gap:14px;align-items:center;font-size:14px;color:var(--muted)}
  .hbar b{color:var(--ink);font-family:'Bricolage Grotesque',sans-serif}
  .card{background:var(--panel);border:1px solid rgba(255,255,255,.06);border-radius:20px;padding:20px;margin:14px 0;animation:fadeUp .4s ease}
  @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  h2{font-family:'Bricolage Grotesque',sans-serif;font-size:19px;margin-bottom:14px}
  h3{font-family:'Bricolage Grotesque',sans-serif;font-size:14px;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;color:var(--muted)}
  label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
  input{width:100%;margin-top:6px;padding:11px 12px;border-radius:9px;border:1px solid #234a8a;background:#0a1c41;color:var(--ink);font-family:inherit;font-size:14px}
  button{font-family:'Outfit';font-weight:600;font-size:14px;border:none;border-radius:12px;padding:12px 20px;cursor:pointer;color:#fff;transition:transform .12s,filter .15s}
  button:active{transform:scale(.96)}
  .primary{background:var(--gold);color:#1a1208}.primary:hover{filter:brightness(1.08)}
  .ghost{background:transparent;color:var(--ink);border:1px solid #2f4f8a}.ghost:hover{background:#16306a}
  .gold{background:linear-gradient(135deg,var(--gold),#d8a72c);color:#2a1c00}
  .red{background:linear-gradient(135deg,var(--red),#9d0d1e)}
  .row{display:flex;gap:10px;flex-wrap:wrap}
  .muted{color:var(--muted);font-size:14px}
  .hide{display:none!important}
  .pill{display:inline-flex;align-items:center;gap:6px;background:rgba(245,197,66,.16);color:var(--gold);padding:5px 13px;border-radius:999px;font-size:14px;font-weight:700;font-family:'Bricolage Grotesque',sans-serif}
  .err{color:#ff8a98;font-size:13px;margin-top:8px;min-height:16px}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media(max-width:620px){.grid2{grid-template-columns:1fr}}
  .tier{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px}
  .pcard{border-radius:14px;padding:16px;cursor:pointer;color:#fff;position:relative;overflow:hidden;border:1px solid rgba(255,255,255,.12);transition:transform .15s,box-shadow .15s;background:linear-gradient(135deg,#1d4ed8,#0a1c41)}
  .pcard:hover{transform:translateY(-4px) scale(1.02);box-shadow:0 12px 26px rgba(0,0,0,.4)}
  .pcard.hot{background:linear-gradient(135deg,var(--red),#7d0a17)}
  .pcard .pn{font-family:'Bricolage Grotesque',sans-serif;font-size:17px;font-weight:700}
  .pcard .pd{font-size:12px;opacity:.85;margin-top:4px}
  .lb{width:100%;border-collapse:collapse}
  .lb th,.lb td{text-align:left;padding:9px 12px;border-bottom:1px solid #234a8a;font-size:14px}
  .lb th{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:1px}
  .lb .pos{font-family:'Bricolage Grotesque',sans-serif;color:var(--gold)}
  .lb .gain{font-family:'Bricolage Grotesque',sans-serif}.lb .gain.neg{color:#ff8a98}
  /* mesa */
  .score{display:flex;gap:14px;justify-content:center;margin-bottom:6px}
  .scorebox{background:var(--panel-2);border-radius:14px;padding:12px 26px;text-align:center;border-top:4px solid var(--teamA);transition:transform .2s}
  .scorebox.bump{transform:scale(1.12)}
  .scorebox.B{border-top-color:var(--teamB)}
  .scorebox b{font-family:'Bricolage Grotesque',sans-serif;font-size:26px;display:block}
  .scorebox small{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:1px}
  .seats{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin:14px 0}
  .seatTag{font-size:13px;color:#eafff7;background:rgba(0,0,0,.32);padding:8px 16px;border-radius:20px;display:inline-flex;flex-direction:column;align-items:center;gap:3px;min-width:120px;border:1px solid transparent}
  .seatTag.active{border-color:var(--gold);box-shadow:0 0 0 2px rgba(245,197,66,.5);animation:glow 1.4s infinite}
  @keyframes glow{50%{box-shadow:0 0 16px 3px var(--gold)}}
  .seatTag .nm{font-family:'Bricolage Grotesque',sans-serif;font-size:15px}
  .seatTag .sub{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
  .dotA{color:var(--teamA)}.dotB{color:var(--teamB)}
  #board{position:relative;background:radial-gradient(ellipse at center,var(--felt),var(--felt-2));border-radius:160px/120px;min-height:340px;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;box-shadow:inset 0 0 70px rgba(0,0,0,.45);border:6px solid #07372a}
  .ends{position:absolute;top:14px;left:50%;transform:translateX(-50%);font-family:'Bricolage Grotesque',sans-serif;font-size:17px;color:#eafff7;background:rgba(0,0,0,.4);padding:9px 22px;border-radius:26px;display:flex;align-items:center;gap:12px;white-space:nowrap;z-index:5}
  .ends b{font-size:25px;color:var(--gold)}
  .emptyboard{color:#bfe3cf;font-style:italic;font-size:16px}
  .snake{position:relative;transform-origin:top center;transition:transform .2s}
  .snake .bt{position:absolute}
  .domino{background:var(--tile);border-radius:7px;border:1px solid var(--tile-edge);box-shadow:0 3px 8px rgba(0,0,0,.35);display:flex;flex-direction:column;user-select:none}
  .domino.h{flex-direction:row}
  .domino .half{flex:1;display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(3,1fr);place-items:center;padding:4px;gap:1px}
  .domino:not(.h) .half:first-child{border-bottom:1px solid var(--tile-edge)}
  .domino.h .half:first-child{border-right:1px solid var(--tile-edge)}
  .pip{width:8px;height:8px;border-radius:50%;background:var(--pip)}
  .hand{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;min-height:120px;margin-top:6px}
  .hd{width:58px;height:108px;flex-direction:column}
  .hd .half:first-child{border-right:0;border-bottom:1px solid var(--tile-edge)}
  .hd .pip{width:12px;height:12px}
  .hd.play{cursor:pointer;outline:3px solid var(--gold);outline-offset:3px;transition:transform .12s}
  .hd.play:hover{transform:translateY(-10px) rotate(-2deg)}
  .hd.dead{opacity:.3}
  .deal{animation:deal .35s ease both}
  @keyframes deal{from{transform:translateY(28px) scale(.7);opacity:0}}
  .place-anim{animation:place .45s cubic-bezier(.2,1.4,.4,1)}
  @keyframes place{0%{transform:scale(.3) rotate(-20deg);opacity:0}60%{transform:scale(1.12)}100%{opacity:1}}
  .turnbar{text-align:center;margin:14px 0;font-family:'Bricolage Grotesque',sans-serif;font-size:21px;min-height:26px}
  .endpick{display:flex;gap:10px;justify-content:center;margin-top:10px}
  #chat{height:170px;overflow:auto;display:flex;flex-direction:column;gap:7px;padding-right:4px}
  .m{background:var(--panel-2);padding:8px 11px;border-radius:10px;font-size:13px;line-height:1.4;animation:fadeUp .25s}
  .m .nm{font-weight:700;font-size:12px;color:var(--gold)}
  .m.sys{background:transparent;color:var(--muted);font-style:italic;text-align:center;font-size:12px}
  .big{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(40px,9vw,84px);font-weight:800;letter-spacing:-2px;pointer-events:none;z-index:60;opacity:0;text-align:center;text-shadow:0 4px 24px rgba(0,0,0,.6)}
  @keyframes pop{0%{opacity:0;transform:scale(.4)}22%{opacity:1;transform:scale(1.12)}78%{opacity:1}100%{opacity:0;transform:scale(1)}}
  .shake{animation:shake .42s}@keyframes shake{0%,100%{transform:none}20%{transform:translate(-7px,3px)}40%{transform:translate(7px,-4px)}60%{transform:translate(-5px,3px)}80%{transform:translate(4px,-2px)}}
  #confetti{position:fixed;inset:0;pointer-events:none;z-index:55;display:none}
  .footnote{color:var(--muted);font-size:11px;text-align:center;margin-top:22px;line-height:1.6}
</style>
</head>
<body>
<canvas id="confetti"></canvas>
<div id="big" class="big"></div>

<div class="wrap">
  <div class="top">
    <div>
      <div class="logo"><span class="flagmark"></span>Domi<span class="d1">Dom</span></div>
      <div class="tag">Dominó Dominicano · 2 contra 2 · online</div>
    </div>
    <div class="hbar" id="hbar"></div>
  </div>

  <!-- AUTH -->
  <div id="auth" class="card" style="max-width:420px;margin:40px auto">
    <h2>Entra a jugar</h2>
    <p class="muted" style="margin-bottom:14px">Crea tu cuenta o entra. Monedas de juego, sin valor real.</p>
    <label>Usuario</label><input id="u" autocomplete="off">
    <div style="height:12px"></div>
    <label>Clave</label><input id="p" type="password">
    <div class="row" style="margin-top:16px">
      <button class="primary" style="flex:1" onclick="doAuth('login')">Entrar</button>
      <button class="ghost" style="flex:1" onclick="doAuth('register')">Crear cuenta</button>
    </div>
    <div id="authErr" class="err"></div>
  </div>

  <!-- LOBBY -->
  <div id="lobby" class="hide">
    <div class="grid2">
      <div class="card">
        <h3>🎲 Buscar partida</h3>
        <p class="muted" style="margin-bottom:12px">Elige mesa. Te emparejamos con otros; si no hay 4 en ~14s, entran bots para que no esperes.</p>
        <div class="tier">
          <div class="pcard" onclick="find(400)"><div class="pn">Mesa 400</div><div class="pd">Pote 1,600</div></div>
          <div class="pcard" onclick="find(1000)"><div class="pn">Mesa 1,000</div><div class="pd">Pote 4,000</div></div>
          <div class="pcard" onclick="find(2000)"><div class="pn">Mesa 2,000</div><div class="pd">Pote 8,000</div></div>
          <div class="pcard hot" onclick="find(5000)"><div class="pn">Mesa 5,000 🔥</div><div class="pd">Pote 20,000</div></div>
        </div>
        <div id="mm" class="muted" style="margin-top:12px"></div>
      </div>
      <div class="card">
        <h3>👥 Sala con amigos</h3>
        <button class="primary" style="width:100%" onclick="createRoom()">Crear sala</button>
        <p class="muted" style="margin:14px 0 6px">¿Tienes un código?</p>
        <input id="joinCode" placeholder="DOMI-XXXX">
        <button class="ghost" style="width:100%;margin-top:10px" onclick="joinRoom()">Unirme a la sala</button>
        <p class="muted" style="margin-top:12px;font-size:12px">El que crea la sala decide cuándo empezar y puede añadir bots.</p>
      </div>
    </div>
    <div class="card">
      <h3>🏆 Leaderboard · ganancia neta</h3>
      <table class="lb"><tbody id="lbBody"></tbody></table>
    </div>
    <div class="footnote">Monedas y skins son de juego, sin valor real. Sin depósitos, sin retiros, sin compras.</div>
  </div>

  <!-- ROOM WAIT -->
  <div id="roomWait" class="hide card" style="max-width:560px;margin:30px auto;text-align:center">
    <h2>Sala <span id="rwCode" class="pill"></span></h2>
    <p class="muted" id="rwBuy" style="margin:8px 0 4px"></p>
    <div id="rwSeats" class="seats"></div>
    <div class="row" id="rwHostCtl" style="justify-content:center"></div>
    <p class="muted" style="margin-top:12px;font-size:12px">Comparte el código. Asientos 1 y 3 = Equipo A · 2 y 4 = Equipo B.</p>
    <button class="ghost" style="margin-top:14px" onclick="leaveRoom()">Salir de la sala</button>
  </div>

  <!-- TABLE -->
  <div id="table" class="hide">
    <div class="score">
      <div class="scorebox" id="boxA"><b id="scA">0</b><small>Equipo A</small></div>
      <div class="scorebox B" id="boxB"><b id="scB">0</b><small>Equipo B</small></div>
    </div>
    <div style="text-align:center;margin-bottom:6px"><span class="pill">💰 Pote <span id="pote">0</span></span> <span class="pill">a 200</span></div>
    <div class="seats" id="tSeats"></div>
    <div id="board"></div>
    <div id="turnMsg" class="turnbar"></div>
    <div id="errBox" style="text-align:center"></div>
    <div id="endpick" class="endpick hide">
      <span class="muted" style="align-self:center">¿Por cuál punta?</span>
      <button class="gold" onclick="choose('L')">◀ Izquierda</button>
      <button class="gold" onclick="choose('R')">Derecha ▶</button>
    </div>
    <div class="hand" id="hand"></div>
    <div style="text-align:center;margin-top:14px">
      <button class="ghost" id="slamBtn" onclick="armSlam()">💥 Estrellar esta ficha</button>
      <button class="ghost" onclick="leaveRoom()">Salir</button>
    </div>
    <div class="card">
      <div id="chat"></div>
      <div class="row" style="margin-top:10px">
        <input id="chatIn" placeholder="Escribe a la mesa…" style="flex:1" onkeydown="if(event.key==='Enter')sendChat()">
        <button class="ghost" onclick="sendChat()">Enviar</button>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const $=id=>document.getElementById(id);
const socket=io();
let ME=null,CODE=null,SEAT=null,G=null,slamNext=false,pendIdx=null,isHost=false,prevScA=0,prevScB=0;

/* ---------- AUTH ---------- */
function doAuth(kind){
  const user=$('u').value.trim(),pass=$('p').value;
  if(!user||!pass){ $('authErr').textContent='Pon usuario y clave.'; return; }
  socket.emit(kind,{user,pass},res=>{
    if(!res.ok){ $('authErr').textContent=res.error; return; }
    ME=res.acc.user; $('authErr').textContent='';
    $('auth').classList.add('hide'); $('lobby').classList.remove('hide');
    hbar(res.acc); socket.emit('getLeaderboard');
  });
}
function hbar(a){ $('hbar').innerHTML=`<span>Hola <b>${a.user}</b></span><span class="pill">💰 <span id="wal">${a.wallet}</span></span><button class="ghost" style="padding:7px 12px" onclick="location.reload()">Salir</button>`; }
function setWallet(w){ const e=$('wal'); if(e) e.textContent=w; }

/* ---------- LOBBY ---------- */
function find(buyin){
  socket.emit('findMatch',{buyin},res=>{
    if(res&&!res.ok){ $('mm').innerHTML='<span style="color:#ff8a98">'+res.error+'</span>'; return; }
    $('mm').textContent='Buscando mesa de '+buyin+'…';
  });
}
socket.on('mmStatus',s=>{ $('mm').textContent=s.inQueue?('En cola… ('+(s.n||1)+'/4) — esperando jugadores o bots'):''; });
function createRoom(){ socket.emit('createRoom',{buyin:1000},res=>{ if(res.ok){ CODE=res.code; SEAT=res.seat; isHost=true; } }); }
function joinRoom(){
  socket.emit('joinRoom',{code:$('joinCode').value},res=>{
    if(!res.ok){ $('mm').innerHTML='<span style="color:#ff8a98">'+res.error+'</span>'; return; }
    CODE=res.code; SEAT=res.seat; isHost=false;
  });
}
socket.on('leaderboard',rows=>{
  $('lbBody').innerHTML='<tr><th>#</th><th>Jugador</th><th>Neto</th><th>Ganadas</th></tr>'+
   (rows.length?rows.map((r,i)=>`<tr><td class="pos">${i+1}</td><td>${r.user}</td><td class="gain ${r.net<0?'neg':''}">${r.net}</td><td>${r.wins}/${r.games}</td></tr>`).join('')
    :'<tr><td colspan="4" class="muted">Aún no hay partidas jugadas</td></tr>');
});

/* ---------- ROOM WAIT ---------- */
socket.on('matched',d=>{ CODE=d.code; SEAT=d.seat; });
socket.on('room',rs=>{
  if(!rs) return; CODE=rs.code;
  if(rs.phase==='lobby'){
    $('lobby').classList.add('hide'); $('table').classList.add('hide'); $('roomWait').classList.remove('hide');
    $('rwCode').textContent=rs.code;
    $('rwBuy').textContent='Mesa de '+rs.buyin+' · pote '+(rs.buyin*4);
    $('rwSeats').innerHTML=rs.seats.map((s,i)=>`<div class="seatTag"><span class="nm">${s?s.name+(s.bot?' 🤖':''):'—'}</span><span class="sub ${i%2===0?'dotA':'dotB'}">Equipo ${i%2===0?'A':'B'}</span></div>`).join('');
    $('rwHostCtl').innerHTML=isHost?`<button class="ghost" onclick="addBot()">+ Bot</button><button class="primary" onclick="startRoom()">Empezar partida</button>`:`<span class="muted">Esperando que el anfitrión empiece…</span>`;
  }
});
function addBot(){ socket.emit('addBot',{code:CODE}); }
function startRoom(){ socket.emit('startRoom',{code:CODE}); }
function leaveRoom(){ socket.emit('leaveRoom'); location.reload(); }

/* ---------- TABLE ---------- */
socket.on('matchStarted',()=>{ ['roomWait','lobby'].forEach(x=>$(x).classList.add('hide')); $('table').classList.remove('hide'); prevScA=prevScB=0; });
socket.on('err',m=>{ $('errBox').innerHTML='<span style="color:#ff8a98">'+m+'</span>'; setTimeout(()=>$('errBox').innerHTML='',2200); });

socket.on('game',v=>{
  G=v; SEAT=v.yourSeat;
  ['roomWait','lobby'].forEach(x=>$(x).classList.add('hide')); $('table').classList.remove('hide');
  if(v.scoreA!==prevScA){ bump($('boxA')); prevScA=v.scoreA; }
  if(v.scoreB!==prevScB){ bump($('boxB')); prevScB=v.scoreB; }
  $('scA').textContent=v.scoreA; $('scB').textContent=v.scoreB; $('pote').textContent=v.pote;
  $('tSeats').innerHTML=v.seats.map((s,i)=>`<div class="seatTag ${i===v.turn&&v.phase==='play'?'active':''}"><span class="nm">${s?s.name+(s.bot?' 🤖':''):'?'}${i===SEAT?' (tú)':''}</span><span class="sub ${i%2===0?'dotA':'dotB'}">Equipo ${i%2===0?'A':'B'} · ${s?s.count:0} fichas</span></div>`).join('');
  drawBoard(v.board,v.left,v.right,v.lastIdx);
  if(v.phase==='handover'){ $('turnMsg').textContent='Fin de la mano. Repartiendo…'; $('hand').innerHTML=''; $('endpick').classList.add('hide'); return; }
  const mine=(v.turn===SEAT&&v.phase==='play');
  $('turnMsg').innerHTML = v.phase!=='play' ? '' : (mine?'<span style="color:var(--gold)">¡Es tu turno!</span>':(v.seats[v.turn]?'Juega <b>'+v.seats[v.turn].name+'</b>…':''));
  renderHand(v,mine);
});

function renderHand(v,mine){
  slamNext=false; pendIdx=null; $('endpick').classList.add('hide');
  const h=$('hand'); h.innerHTML='';
  v.yourHand.forEach((t,idx)=>{
    const ok=mine&&v.legal.includes(idx);
    const e=tile(t,true); e.classList.add('deal'); e.style.animationDelay=(idx*45)+'ms';
    e.classList.add(ok?'play':'dead');
    if(ok) e.onclick=()=>pick(idx,t);
    h.appendChild(e);
  });
  const b=$('slamBtn'); b.textContent='💥 Estrellar esta ficha'; b.classList.remove('gold'); b.classList.add('ghost');
}
function pick(idx,t){
  if(!G.board||G.board.length===0){ doPlay(idx,'R'); return; }
  const fL=t.includes(G.left),fR=t.includes(G.right);
  if(fL&&fR&&G.left!==G.right){ pendIdx=idx; $('endpick').classList.remove('hide'); }
  else doPlay(idx,fL?'L':'R');
}
function choose(side){ $('endpick').classList.add('hide'); const i=pendIdx; pendIdx=null; doPlay(i,side); }
function doPlay(idx,side){ socket.emit('play',{code:CODE,idx,side,slam:slamNext}); slamNext=false; }
function armSlam(){ slamNext=!slamNext; const b=$('slamBtn'); b.textContent=slamNext?'💥 ¡ARMADO! pon tu ficha':'💥 Estrellar esta ficha'; b.classList.toggle('gold',slamNext); b.classList.toggle('ghost',!slamNext); }

/* ---------- CHAT ---------- */
socket.on('chat',m=>{
  const c=$('chat');
  const d=document.createElement('div');
  d.className='m'+(m.sys?' sys':'');
  d.innerHTML=m.sys?m.text:`<div class="nm">${esc(m.name)}</div>${esc(m.text)}`;
  c.appendChild(d); c.scrollTop=c.scrollHeight;
  while(c.children.length>60) c.removeChild(c.firstChild);
});
function esc(s){ return (''+s).replace(/[<>&]/g,x=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[x])); }
function sendChat(){ const i=$('chatIn'); if(!i.value.trim())return; socket.emit('chat',{code:CODE,text:i.value}); i.value=''; }

/* ---------- AUDIO + ESTRELLÓN ---------- */
let AC;
function ac(){ try{ AC=AC||new (window.AudioContext||window.webkitAudioContext)(); if(AC.state==='suspended')AC.resume(); return AC; }catch(e){ return null; } }
function beep(f,d,t,g,delay=0){ const c=ac(); if(!c)return; const o=c.createOscillator(),v=c.createGain(); o.type=t||'sine'; o.frequency.value=f; v.gain.value=g||.1; o.connect(v); v.connect(c.destination); const s=c.currentTime+delay; o.start(s); v.gain.setValueAtTime(v.gain.value,s); v.gain.exponentialRampToValueAtTime(.0001,s+d); o.stop(s+d); }
function clack(){ const c=ac(); if(!c)return; const len=(c.sampleRate*.06)|0,b=c.createBuffer(1,len,c.sampleRate),d=b.getChannelData(0); for(let i=0;i<len;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/len,3); const s=c.createBufferSource(),g=c.createGain(); s.buffer=b; g.gain.value=.3; s.connect(g); g.connect(c.destination); s.start(); beep(150,.07,'square',.05); }
function slamFX(){
  const c=ac();
  if(c){ const len=(c.sampleRate*.16)|0,b=c.createBuffer(1,len,c.sampleRate),d=b.getChannelData(0);
    for(let i=0;i<len;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/len,2.2);
    const s=c.createBufferSource(),g=c.createGain(); s.buffer=b; g.gain.value=.9; s.connect(g); g.connect(c.destination); s.start();
    beep(70,.22,'square',.8); beep(110,.16,'sawtooth',.5); beep(190,.1,'square',.35); }
  flashBig('¡PLAM! 💥','var(--gold)');
  const w=document.querySelector('.wrap'); w.classList.add('shake'); setTimeout(()=>w.classList.remove('shake'),420);
}
socket.on('slam',()=>slamFX());
function flashBig(txt,color){ const e=$('big'); e.textContent=txt; e.style.color=color||'var(--gold)'; e.style.animation='none'; e.offsetHeight; e.style.animation='pop 1.4s ease'; }

/* ---------- CONFETI ---------- */
const cv=$('confetti'); let cx=cv.getContext('2d'),parts=[],raf=null;
function rs(){ cv.width=innerWidth; cv.height=innerHeight; } addEventListener('resize',rs); rs();
function burst(n){
  cv.style.display='block';
  const cols=['#f5c542','#ce1126','#1d4ed8','#fff','#28e0c8'];
  for(let i=0;i<n;i++) parts.push({x:innerWidth/2,y:innerHeight/2,vx:(Math.random()-.5)*16,vy:(Math.random()-.5)*16-4,g:.3,c:cols[(Math.random()*cols.length)|0],s:6+Math.random()*7,life:90});
  if(!raf) anim();
}
function anim(){
  cx.clearRect(0,0,cv.width,cv.height);
  parts=parts.filter(p=>p.life>0);
  parts.forEach(p=>{ p.vy+=p.g; p.x+=p.vx; p.y+=p.vy; p.life--; cx.fillStyle=p.c; cx.fillRect(p.x,p.y,p.s,p.s); });
  if(parts.length) raf=requestAnimationFrame(anim); else { raf=null; cv.style.display='none'; }
}
function bump(box){ box.classList.add('bump'); setTimeout(()=>box.classList.remove('bump'),220); }
const rnd=a=>a[(Math.random()*a.length)|0];

/* ---------- TABLERO (serpiente real) ---------- */
const PIPS={0:[],1:[4],2:[0,8],3:[0,4,8],4:[0,2,6,8],5:[0,2,4,6,8],6:[0,2,3,5,6,8]};
function half(n){ const h=document.createElement('div'); h.className='half'; for(let i=0;i<9;i++){ const c=document.createElement('div'); if(PIPS[n].includes(i)) c.className='pip'; h.appendChild(c);} return h; }
function tile(t,hand){ const d=document.createElement('div'); d.className='domino'+(hand?' hd':' h'); d.appendChild(half(t[0])); d.appendChild(half(t[1])); return d; }

function drawBoard(board,left,right,lastIdx){
  const b=$('board'); b.innerHTML='';
  if(!board||board.length===0){ b.innerHTML='<div class="emptyboard">La mesa está vacía — esperando la primera ficha</div>'; return; }
  const ends=document.createElement('div'); ends.className='ends';
  ends.innerHTML=`<span>Puntas:</span> <b>${left}</b> <span style="opacity:.6">ó</span> <b>${right}</b>`;
  const L=58,S=30,VRUN=2;
  const wrap=document.createElement('div'); wrap.className='snake';
  const avail=(b.clientWidth||innerWidth)-70;
  const minX=L, maxX=Math.max(L*4,avail);
  let P={x:L,y:L},dir='R',lastH='R',vCount=0,x0=1e9,y0=1e9,x1=-1e9,y1=-1e9; const els=[];
  for(let i=0;i<board.length;i++){
    const t=board[i],dbl=t[0]===t[1]; let a,th,vert,vals;
    if(dir==='D'){ if(dbl){vert=false;a=S;th=L;}else{vert=true;a=L;th=S;} vals=[t[0],t[1]]; }
    else { if(dbl){vert=true;a=S;th=L;}else{vert=false;a=L;th=S;} vals=dir==='L'?[t[1],t[0]]:[t[0],t[1]]; }
    const W=vert?S:L,H=vert?L:S; let Lx,Ty;
    if(dir==='R'){ Lx=P.x; Ty=P.y-th/2; }
    else if(dir==='L'){ Lx=P.x-W; Ty=P.y-th/2; }
    else { Ty=P.y; Lx=P.x-W/2; }
    const e=tile(vals,false); e.classList.add('bt');
    e.style.cssText+=`;left:${Lx}px;top:${Ty}px;width:${W}px;height:${H}px`;
    if(i===lastIdx){ e.classList.add('place-anim'); e.style.zIndex=2; e.style.outline='3px solid var(--gold)'; }
    els.push(e); wrap.appendChild(e);
    x0=Math.min(x0,Lx);y0=Math.min(y0,Ty);x1=Math.max(x1,Lx+W);y1=Math.max(y1,Ty+H);
    if(dir==='R')P={x:P.x+a,y:P.y}; else if(dir==='L')P={x:P.x-a,y:P.y}; else P={x:P.x,y:P.y+a};
    if(dir==='R'&&P.x>=maxX){dir='D';vCount=0;lastH='R';}
    else if(dir==='L'&&P.x<=minX){dir='D';vCount=0;lastH='L';}
    else if(dir==='D'){vCount++;if(vCount>=VRUN)dir=lastH==='R'?'L':'R';}
  }
  els.forEach(el=>{el.style.left=(parseFloat(el.style.left)-x0)+'px';el.style.top=(parseFloat(el.style.top)-y0)+'px';});
  const W=x1-x0,Hh=y1-y0; wrap.style.width=W+'px'; wrap.style.height=Hh+'px';
  b.appendChild(ends); b.appendChild(wrap);
  clack();
  requestAnimationFrame(()=>{ const aw=(b.clientWidth||900)-46,ah=Math.max(240,(b.clientHeight||420)-86);
    wrap.style.transform='scale('+Math.max(.14,Math.min(1,aw/W,ah/Hh))+')'; });
}

/* ---------- FIN ---------- */
socket.on('handOver',d=>{ $('turnMsg').textContent=`Fin de la mano (${d.scoreA}-${d.scoreB})…`; });
socket.on('matchOver',d=>{
  setWallet(d.acc.wallet);
  if(d.won){ flashBig(d.skunk?'¡POLLONA! 🏆':'¡GANARON! 🏆','var(--gold)'); burst(180);
    beep(523,.12,'square',.08);beep(659,.12,'square',.08,.12);beep(784,.2,'square',.08,.24); }
  else { flashBig(rnd(['Te trancaron 😕','La próxima es tuya','¡Dale revancha!']),'#ff8a98'); beep(330,.25,'sawtooth',.06);beep(233,.4,'sawtooth',.06,.16); }
  const w=document.querySelector('.wrap'); w.classList.add('shake'); setTimeout(()=>w.classList.remove('shake'),420);
  $('turnMsg').textContent=(d.won?'Ganaste ':'Perdiste ')+d.scoreA+'-'+d.scoreB+'. Volviendo al lobby…';
  setTimeout(()=>{ $('table').classList.add('hide'); $('lobby').classList.remove('hide'); socket.emit('getLeaderboard'); }, 4000);
});
</script>
</body>
</html>

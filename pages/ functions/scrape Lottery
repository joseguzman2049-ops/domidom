import { createClientFromRequest } from 'npm:@base44/sdk@0.8.25';

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);

    // Use InvokeLLM with internet search to get today's lottery results
    const today = new Date().toLocaleDateString('es-DO', { 
      year: 'numeric', month: 'long', day: 'numeric',
      timeZone: 'America/Santo_Domingo'
    });

    const result = await base44.asServiceRole.integrations.Core.InvokeLLM({
      prompt: `Busca los resultados de loterías dominicanas del día de hoy ${today}. 
      Necesito los resultados de: Anguila 8AM, Anguila 9AM, Anguila 10AM, Anguila 11AM, Anguila 12PM, Anguila 1PM, Anguila 2PM, Anguila 3PM, Anguila 4PM, Anguila 5PM, LoteDom, La Primera, La Suerte, King Lottery, Lotería Real, Florida Dia, New York, Nacional Gana Más, Haiti Bolet, Queen Lottery, Georgia Dia, New Jersey, Puerto Rico.
      
      Busca en oceanbluecasino.com/lottery o en las páginas oficiales de cada lotería.
      
      Devuelve un JSON con esta estructura exacta:
      {
        "lotteries": [
          {
            "lottery_name": "nombre",
            "draw_date": "fecha en español",
            "closing_time": "hora de cierre ej: 7:55 AM",
            "numbers": ["num1", "num2", "num3"],
            "previous_draws": [
              { "date": "22 de mayo", "numbers": ["n1", "n2", "n3"] }
            ]
          }
        ]
      }`,
      add_context_from_internet: true,
      model: 'gemini_3_flash',
      response_json_schema: {
        type: "object",
        properties: {
          lotteries: {
            type: "array",
            items: {
              type: "object",
              properties: {
                lottery_name: { type: "string" },
                draw_date: { type: "string" },
                closing_time: { type: "string" },
                numbers: { type: "array", items: { type: "string" } },
                previous_draws: {
                  type: "array",
                  items: {
                    type: "object",
                    properties: {
                      date: { type: "string" },
                      numbers: { type: "array", items: { type: "string" } }
                    }
                  }
                }
              }
            }
          }
        }
      }
    });

    const lotteries = result.lotteries || [];

    if (lotteries.length === 0) {
      return Response.json({ error: 'No se obtuvieron resultados' }, { status: 500 });
    }

    const scrapedAt = new Date().toISOString();

    // Replace all existing results
    const existing = await base44.asServiceRole.entities.LotteryResult.list('created_date', 200);
    for (const item of existing) {
      await base44.asServiceRole.entities.LotteryResult.delete(item.id);
    }

    // Logo URLs map
    const logoMap = {
      'Anguila': 'https://oceanbluecasino.com/storage/images/lottery-image-1757233090.png',
      'LoteDom': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232974.png',
      'La Primera': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232555.png',
      'La Suerte': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232893.png',
      'King Lottery': 'https://oceanbluecasino.com/storage/images/lottery-image-1757233268.png',
      'Loteria Real': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232588.png',
      'Lotería Real': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232588.png',
      'Florida': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232952.png',
      'New York': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232744.png',
      'Nacional': 'https://oceanbluecasino.com/storage/images/lottery-image-1757232642.png',
      'Haiti': 'https://oceanbluecasino.com/storage/images/lottery-image-1760669040.png',
      'Queen': 'https://oceanbluecasino.com/storage/images/lottery-image-1762432323.png',
      'Georgia': 'https://oceanbluecasino.com/storage/images/lottery-image-1759889907.png',
      'New Jersey': 'https://oceanbluecasino.com/storage/images/lottery-image-1759889543.png',
      'Puerto Rico': 'https://oceanbluecasino.com/storage/images/lottery-image-1759890636.png',
    };

    function getLogoUrl(name) {
      for (const [key, url] of Object.entries(logoMap)) {
        if (name.includes(key)) return url;
      }
      return '';
    }

    for (const lottery of lotteries) {
      await base44.asServiceRole.entities.LotteryResult.create({
        ...lottery,
        logo_url: getLogoUrl(lottery.lottery_name),
        scraped_at: scrapedAt
      });
    }

    return Response.json({ success: true, count: lotteries.length, scraped_at: scrapedAt });

  } catch (error) {
    return Response.json({ error: error.message }, { status: 500 });
  }
});
